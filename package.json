{
  "name": "mic-drop",
  "version": "0.1.0",
  "description": "Turn a Jira ticket into an isolated git worktree with Claude Code running automatically — in one command.",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "mic-drop": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["jira", "git", "worktree", "claude", "cli", "ai"],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "keytar": "^7.9.0",
    "ora": "^8.0.1",
    "simple-git": "^3.22.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
